% ----------- Header / Footer -----------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\textbf{MROB--VIU} • \nouppercase{\leftmark}}
\fancyhead[R]{\textit{\viudocumenttypename}}
\fancyfoot[C]{\small\color{UniPrimary}\textbf{Página \thepage{} de \pageref{LastPage}}}
\renewcommand{\headrulewidth}{0.35pt}
\renewcommand{\headrule}{%
  \hbox to\headwidth{%
    \color{UniPrimary!55}\leaders\hrule height \headrulewidth\hfill
  }%
}
\renewcommand{\footrulewidth}{0pt}

\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyhead[L]{\textbf{MROB--VIU} • \nouppercase{\leftmark}}
  \fancyhead[R]{\textit{\viudocumenttypename}}
  \fancyfoot[C]{\small\color{UniPrimary}\textbf{Página \thepage{} de \pageref{LastPage}}}
  \renewcommand{\headrulewidth}{0.35pt}
  \renewcommand{\headrule}{%
    \hbox to\headwidth{%
      \color{UniPrimary!55}\leaders\hrule height \headrulewidth\hfill
    }%
  }
}

% ----------- Section formatting -----------
\titleformat{\section}
  {\bfseries\color{UniDark}\fontsize{16}{18}\selectfont}
  {\color{UniPrimaryDeep}\thesection}
  {0.7em}{}

\titleformat{\subsection}
  {\bfseries\color{UniDark}\fontsize{13}{16}\selectfont}
  {\color{UniPrimaryDeep}\thesubsection}
  {0.6em}{}

\titlespacing*{\section}{0pt}{0.9em}{0.5em}
\titlespacing*{\subsection}{0pt}{0.7em}{0.35em}
\renewcommand{\sectionmark}[1]{\markboth{#1}{}}

\setlist[itemize]{left=1.2em}
\setlist[enumerate]{left=1.6em}

% ----------- Cover page -----------
\newcommand{\makeviucover}{%
\newgeometry{left=1.8cm,right=1.8cm,top=1.8cm,bottom=2.2cm}
\hypersetup{pageanchor=false}
\begin{titlepage}
    \thispagestyle{empty}
    \pagecolor{UniPrimaryDeep}
    \color{white}

    \begin{tikzpicture}[remember picture,overlay]
        \IfFileExists{\viucoveroverlayleftpath.png}{%
            \node[anchor=south west,opacity=0.25] at ($(current page.south west)+(-0.2cm,-0.4cm)$)
            {\includegraphics[height=18.5cm]{\viucoveroverlayleftpath}};
        }{}%
        \IfFileExists{\viucoveroverlayrightpath.png}{%
            \node[anchor=north east,opacity=0.25] at ($(current page.north east)+(0.4cm,0.3cm)$)
            {\includegraphics[height=18.5cm]{\viucoveroverlayrightpath}};
        }{}%
    \end{tikzpicture}

    \raggedright

    \IfFileExists{\viucoverlogopath.pdf}{%
        \includegraphics[height=1.7cm]{\viucoverlogopath}\par
    }{%
        \IfFileExists{\viucoverlogopath.png}{%
            \includegraphics[height=1.7cm]{\viucoverlogopath}\par
        }{}%
    }

    \vspace*{2.1cm}

    {\bfseries\fontsize{14}{16}\selectfont \viumastername\par}
    \vspace{3pt}
    {\fontsize{20}{23}\selectfont \viuinstitutionname\par}

    \vspace*{2.6cm}

    {\bfseries\fontsize{30}{36}\selectfont \viudocumenttypename\par}
    \vspace{6pt}
    {\color{UniLight}\bfseries\fontsize{16}{20}\selectfont \viuthesistitle\par}
    \vspace{8pt}
    {\fontsize{13}{15}\selectfont \viuversionlabel\par}

    \vfill

    {\color{UniLight}\rule{\textwidth}{0.9pt}\par}
    \vspace{1.0cm}

    \begin{minipage}[t]{0.70\textwidth}
        \raggedright
        {\fontsize{11}{14}\selectfont
        \textbf{Estudiante}\quad \viustudentname\par
        \vspace{4pt}
        \textbf{Tutor/a}\quad \viututorname\par
        \vspace{4pt}
        \textbf{Fecha}\quad \viuproposaldate\par}
    \end{minipage}
\end{titlepage}
\restoregeometry
\pagecolor{white}
\color{UniDark}
\setcounter{page}{1}
\hypersetup{pageanchor=true}
}
